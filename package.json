{
	"name": "template-app",
	"private": true,
	"packageManager": "bun@1.3.0",
	"workspaces": [
		"apps/*",
		"packages/*"
	],
	"scripts": {
		"dev": "turbo run dev",
		"build": "turbo run build",
		"test": "turbo run test",
		"lint": "biome check .",
		"typecheck": "turbo run typecheck",
		"format": "prettier --write \"**/*.{ts,tsx,js,jsx}\" --plugin prettier-plugin-tailwindcss && biome format --write .",
		"format:check": "prettier --check \"**/*.{ts,tsx,js,jsx}\" --plugin prettier-plugin-tailwindcss && biome format .",
		"storybook": "turbo run storybook",
		"build-storybook": "turbo run build-storybook",
		"test:e2e": "turbo run test:e2e",
		"prepare": "husky"
	},
	"lint-staged": {
		"*.{ts,tsx,js,jsx}": [
			"prettier --write --plugin prettier-plugin-tailwindcss",
			"biome check --write --no-errors-on-unmatched"
		],
		"*.{json,css,md}": "biome check --write --no-errors-on-unmatched"
	},
	"overrides": {
		"import-in-the-middle": "^3.0.0"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.0.0",
		"husky": "^9.1.7",
		"lint-staged": "^16.4.0",
		"prettier": "^3.4.0",
		"prettier-plugin-tailwindcss": "^0.6.0",
		"turbo": "^2.4.0"
	}
}
