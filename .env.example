# Required
DATABASE_URL=                     # Neon Postgres connection string

# Optional — app works without these, features degrade gracefully
SESSION_SECRET=                   # HMAC key for session cookies
NEXT_PUBLIC_SENTRY_DSN=           # Sentry client DSN (errors silently skipped if missing)
SENTRY_AUTH_TOKEN=                # Sentry source maps (CI only)
NEXT_PUBLIC_POSTHOG_KEY=          # PostHog analytics (tracking silently skipped if missing)
NEXT_PUBLIC_POSTHOG_HOST=        # PostHog API host (defaults to https://us.i.posthog.com)
TURBO_TOKEN=                      # Turborepo remote cache (optional)
TURBO_TEAM=                       # Vercel team for remote cache (optional)

# Dobby — Admin
DOBBY_ADMIN_PASSWORD_HASH=        # bcrypt hash for admin UI password

# Dobby — Job config
DOBBY_HOURLY_RATE=100             # FLOPS per hour (default: 100)
DOBBY_MAX_JOB_HOURS=6             # Max job duration in hours (default: 6)
DOBBY_ACCOUNT_VCPU_LIMIT=24      # Account vCPU quota (default: 24)
DOBBY_VM_CPU=4                    # vCPU per runner (default: 4)
DOBBY_CONTAINER_IMAGE=            # Custom runner Docker image (optional, uses ECR default)
DOBBY_CALLBACK_SECRET=            # Shared secret for runner → API callbacks
DOBBY_CALLBACK_URL=               # Base URL for runner callbacks (e.g. https://your-app.vercel.app)

# Dobby — Telegram notifications (silently skipped if missing)
DOBBY_TELEGRAM_BOT_TOKEN=        # Telegram Bot API token
DOBBY_TELEGRAM_CHAT_ID=          # Telegram chat ID for notifications

# Dobby — AWS
AWS_REGION=us-east-1              # AWS region (default: us-east-1)
AWS_ACCESS_KEY_ID=                # AWS credentials
AWS_SECRET_ACCESS_KEY=            # AWS credentials
ECS_CLUSTER_ARN=                  # ECS cluster ARN from CDK output
ECS_TASK_DEFINITION_ARN=          # ECS task definition ARN from CDK output
ECS_SUBNETS=                      # Comma-separated subnet IDs from CDK output
ECS_SECURITY_GROUPS=              # Comma-separated security group IDs from CDK output
KMS_KEY_ID=                       # KMS key ID for secret encryption

# Dobby — MPP (Machine Payments Protocol)
MPP_ENDPOINT=                     # MPP API endpoint
MPP_API_KEY=                      # MPP API key
